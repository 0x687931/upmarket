#!/usr/bin/env bash
set -euo pipefail

# Self-healing generated docs.
#
# CI runs `scripts/docs/generate_repo_docs.py --check` via gate.sh, which fails
# the build when docs/generated/ drifts from the source it summarizes. This hook
# regenerates those docs (write mode) and re-stages them when needed, so
# committed docs stay in sync with tracked source before commit.
#
# Installed by scripts/git-hooks/install.sh. Set UPMARKET_HOOK_DRYRUN=1 to print
# the decision without regenerating (used for testing the hook).

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v python3 >/dev/null 2>&1; then
  echo "error: pre-commit hook needs python3 to regenerate docs/generated/" >&2
  echo "       install python3 or commit with --no-verify if you have regenerated manually" >&2
  exit 1
fi

if [[ "${UPMARKET_HOOK_DRYRUN:-0}" == "1" ]]; then
  if python3 scripts/docs/generate_repo_docs.py --check >/dev/null 2>&1; then
    echo "[pre-commit] docs/generated/ is already current"
    exit 0
  fi
  echo "[pre-commit] docs/generated/ would be regenerated"
  exit 0
fi

# If the generated docs are already current, keep the commit fast.
# Otherwise, regenerate and re-stage them once.
if python3 scripts/docs/generate_repo_docs.py --check >/dev/null 2>&1; then
  exit 0
fi

python3 scripts/docs/generate_repo_docs.py >/dev/null
git add docs/generated/
