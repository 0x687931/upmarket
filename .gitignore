# ML model weight formats (formats not used by this project's pinned models)
*.mlpackage/
*.mlmodel

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Environment
.env
.env.local
# Ignore personal Claude config, but track shared team enforcement (worktree guard).
.claude/*
!.claude/settings.json
!.claude/hooks
.claude/hooks/*
!.claude/hooks/require-worktree.sh

# Dependencies
Upmarket/Python/python-stdlib/
# Python.xcframework is tracked via Git LFS — do not ignore it

# Archives
*.xcarchive
.venv/

# Generated CI/local reports
reports/
Upmarket/LocalDev.xcconfig

# SwiftPM build artifacts in vendored packages
Upmarket/Vendor/*/.build/
