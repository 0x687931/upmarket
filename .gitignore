**/*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
/build/
Upmarket/build/
DerivedData/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivep
*.xccheckout
*.moved-aside
*.xcuserstate

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
