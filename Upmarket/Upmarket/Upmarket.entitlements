<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Network: only for model downloads on first use -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File access: user-selected files via Open/Save panels -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- App Groups: needed for sharing data with extensions -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.upmarket.app</string>
    </array>

    <!-- Background Assets: receive AI-model downloads scheduled by UpmarketBAExtension -->
    <key>com.apple.developer.background-assets</key>
    <true/>

    <!-- CloudKit: public feature availability flags only -->
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.upmarket.app</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <key>com.apple.developer.icloud-container-environment</key>
    <string>$(UPMARKET_CLOUDKIT_ENVIRONMENT)</string>
</dict>
</plist>
